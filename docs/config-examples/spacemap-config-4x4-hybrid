# Example: 6x2 rects grid with tokyonight theme
GRID_COLS=6
GRID_ROWS=2
CELL_STYLE=rects            # rects | icons | thumbnails | simple
HOTKEY=ctrl+space
SOCKET_HEALTH_INTERVAL=60
UI_SCALE=0.3                # 0.0–1.0 (effective: 0.5x–4.0x)
THEME=tokyonight
SHOW_MODE=all               # all | active
MAX_SPACES=16
AUTO_HIDE_TIMEOUT=0         # 0 = disabled, seconds
BACKGROUND_ALPHA=1.0        # 0.0–1.0
MODE=auto                   # light | dark | auto
ICON_SCALE=0.9              # 0.0–1.0 (effective: 0.2x–1.0x)
SHOW_SPACE_NUMBERS=true     # true | false
SHOW_SPACE_NAMES=false      # true | false
SHOW_ICON_STRIP=true        # true | false
SHOW_MULTI_APP_ICONS=false  # true | false
HIDE_MENUBAR_ICON=false     # true | false
VIM_KEYS=false              # true | false
ARROW_KEYS=false            # true | false
SPACE_NAMES=                # comma-separated, e.g. "1:Term,2:Code"
